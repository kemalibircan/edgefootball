# Database
DATABASE_URL=postgresql://football:football@localhost:5432/football
DB_URL=postgresql://football:football@localhost:5432/football
DB_RUN_STARTUP_MIGRATIONS=true
DB_MIGRATIONS_DIR=migrations

# Redis
REDIS_URL=redis://localhost:6379/0

# SportMonks API
SPORTMONKS_API_TOKEN=your-sportmonks-token-here

# OpenAI API
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
DALLE_MODEL=dall-e-3
DAILY_GENERATION_ENABLED=true

# Auth & Security
AUTH_SECRET=change-this-to-a-secure-random-string
AUTH_SECRET_FALLBACKS=
AUTH_TOKEN_TTL_HOURS=72
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_COOKIE_NAME=football_ai_refresh
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_INITIAL_CREDITS=100

# Credit Costs
SIMULATION_CREDIT_COST=7
AI_COMMENTARY_CREDIT_COST=10
MODEL_TRAINING_CREDIT_COST=5
AI_QUERY_CREDIT_COST=10
COUPON_GENERATION_CREDIT_COST=15

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_ADDRESS=noreply@footballai.com
SMTP_FROM_NAME=Football AI
SMTP_USE_TLS=true

# Google OAuth (optional)
GOOGLE_WEB_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Bootstrap Superadmin
BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@footballai.local
BOOTSTRAP_SUPERADMIN_PASSWORD=superadmin123

# Feature Flags
DUMMY_MODE=false
LOG_LEVEL=INFO

# SEO
SITE_BASE_URL=http://localhost:3001
